{
  "name": "obolus-backend",
  "version": "2.0.0",
  "private": true,
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "tsc --noEmit",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:migrate:deploy": "prisma migrate deploy",
    "db:seed": "tsx prisma/seed.ts"
  },
  "dependencies": {
    "@prisma/client": "6.6.0",
    "bcrypt": "6.0.0",
    "cors": "2.8.5",
    "date-fns": "4.1.0",
    "dotenv": "^17.3.1",
    "express": "4.22.1",
    "express-rate-limit": "7.5.0",
    "fast-csv": "5.0.2",
    "jsonwebtoken": "9.0.2",
    "multer": "1.4.5-lts.2",
    "node-cron": "3.0.3",
    "pdfkit": "0.16.0",
    "zod": "3.24.2"
  },
  "devDependencies": {
    "@types/bcrypt": "5.0.2",
    "@types/cors": "2.8.17",
    "@types/express": "5.0.1",
    "@types/jsonwebtoken": "9.0.9",
    "@types/multer": "1.4.12",
    "@types/node": "22.13.14",
    "@types/node-cron": "3.0.11",
    "@types/pdfkit": "0.13.8",
    "@types/supertest": "6.0.2",
    "prisma": "6.6.0",
    "supertest": "7.1.0",
    "tsx": "4.19.3",
    "typescript": "5.8.2",
    "vitest": "3.1.1"
  }
}
